# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key-123456
JWT_SECRET_KEY=change-this-to-another-random-key-789012

# Database
DATABASE_URL=sqlite:///ihis.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/ihis

# Email Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Upload Configuration
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=uploads

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5500

# AI Configuration (Future)
AI_ENABLED=false
AI_MODEL_PATH=models/

# Security
BCRYPT_LOG_ROUNDS=12
JWT_ACCESS_TOKEN_EXPIRES=3600